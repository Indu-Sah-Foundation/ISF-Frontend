# Copy this file to `.env.local` and fill in real values.
# `.env*` is gitignored (with `.env.example` as the only exception), so
# the file you actually edit never lands in source control.
#
# To get the real production backend URL:
#   - Ask the project maintainer, or
#   - Azure portal → App Services → your Go backend → Overview → "Default domain"

# Required. The Go backend the frontend talks to.
#   Local development (backend running on your laptop):
#     VITE_ISF_API=http://localhost:8080
#   Staging / prod (point at your deployed App Service):
#     VITE_ISF_API=https://<your-app-service>.azurewebsites.net
VITE_ISF_API=
